{
  "version": 2,
  "name": "mathematico-backend",
  "functions": {
    "Backend/index.js": {
      "runtime": "@vercel/node@3",
      "maxDuration": 120,
      "memory": 2048
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/Backend/index.js" }
  ],
  "regions": ["iad1"]
}