{
  "version": 2,
  "name": "mathematico-backend",
  "functions": {
    "Backend/index.js": {
      "runtime": "@vercel/node@3",
      "maxDuration": 120,
      "memory": 2048
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/Backend/index.js" },
    { "src": "/health", "dest": "/Backend/index.js" },
    { "src": "/", "dest": "/Backend/index.js" }
  ],
  "regions": ["iad1"]
}