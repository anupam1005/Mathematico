{
  "cli": {
    "version": ">= 5.9.1",
    "appVersionSource": "local"
  },
  "build": {
    "production": {
      "node": "20.0.0",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.mathematico.in",
        "EXPO_PUBLIC_ENV": "production"
      },
      "channel": "production"
    },
    "preview": {
      "node": "20.0.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.mathematico.in",
        "EXPO_PUBLIC_ENV": "preview"
      },
      "channel": "preview"
    },
    "development": {
      "node": "20.0.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://api.mathematico.in",
        "EXPO_PUBLIC_ENV": "development"
      },
      "channel": "development"
    }
  }
}